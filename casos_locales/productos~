INSERT INTO products (
    referencia,
    descripcion,
    codigo_articulo,
    cod_barras,
    cod_barras2,
    cod_barras3,
    marca,
    descripcion_adicional,
    categoria_id,
    seccion_id,
    subseccion_id
)
SELECT 
    c."Referencia",
    c."Descripción",
    c."Código" AS codigo_articulo,                    -- Aquí estaba el error
    c."Cód. Barras",
    c."Cód Barras 2",
    c."Cód Barras 3",
    c."Serie" AS marca,                               -- Usamos la primera columna Serie
    NULL AS descripcion_adicional,
    cat.id AS categoria_id,
    sec.id AS seccion_id,
    sub.id AS subseccion_id
FROM temp_compras c
LEFT JOIN categories cat ON cat.name = c."Seccion"
LEFT JOIN sections sec 
    ON sec.category_id = cat.id 
   AND sec.name = c."Família"
LEFT JOIN sub_sections sub 
    ON sub.section_id = sec.id 
   AND sub.name = c."SubFamilia"
WHERE c."Referencia" IS NOT NULL 
  AND c."Descripción" IS NOT NULL
  AND NOT EXISTS (
        SELECT 1 
        FROM products p 
        WHERE p.referencia = c."Referencia" 
          AND p.descripcion = c."Descripción"
      )
ON CONFLICT (referencia, descripcion) 
DO NOTHING;


























